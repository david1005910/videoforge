{
  "name": "videoforge",
  "version": "0.0.1",
  "private": true,
  "description": "macOS-native AI video creation studio (Intel 16GB Monterey 최적화)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @videoforge/desktop dev",
    "build": "pnpm -r build",
    "dist:mac:local": "pnpm --filter @videoforge/desktop dist:mac:local",
    "dist:mac:universal": "pnpm --filter @videoforge/desktop dist:mac:universal",
    "dist:mac": "pnpm dist:mac:local",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @videoforge/desktop test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc -b --noEmit",
    "clean": "rimraf '**/out' '**/dist' '**/build' '**/release' '**/*.tsbuildinfo'",
    "clean:cache": "pnpm --filter @videoforge/desktop clean:cache",
    "kill:dev": "pkill -f electron; pkill -f vite; echo 'killed dev processes'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@types/node": "20.16.0",
    "eslint": "9.13.0",
    "eslint-plugin-react": "7.37.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "globals": "15.11.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "rimraf": "6.0.1",
    "typescript": "5.6.3",
    "typescript-eslint": "8.11.0"
  }
}
